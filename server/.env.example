# Copy this file to ".env" and fill in real values.
# ".env" is gitignored — never commit real secrets.

# Port the API listens on (Render sets this automatically in prod)
PORT=5001

# MongoDB connection string.
#   Local dev:  mongodb://127.0.0.1:27017/eshop
#   Production: a MongoDB Atlas URI (keep the /eshop database name)
MONGODB_URI=mongodb://127.0.0.1:27017/eshop

# Secret used to sign JWT login tokens. Use a long random string.
JWT_SECRET=replace_with_a_long_random_secret

# Frontend origin(s) allowed to call this API, comma-separated.
# Set this on Render to your real Netlify URL, e.g.
#   ALLOWED_ORIGINS=https://your-site.netlify.app
# (localhost:5173 is always allowed for local dev.)
ALLOWED_ORIGINS=

# Email / OTP delivery
#   true  -> no real email; an Ethereal preview URL is returned (testing)
#   false -> sends real email via Gmail using SMTP_USER / SMTP_PASS
USE_ETHEREAL=true

# Only needed when USE_ETHEREAL=false (Gmail App Password, 16 chars)
# SMTP_USER=youremail@gmail.com
# SMTP_PASS=your_16_char_gmail_app_password
